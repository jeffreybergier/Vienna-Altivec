+// [libcurl callback] Body chunk received — append to an NSMutableData accumulator.
+// Runs on the detached curl worker thread.
+static size_t asi_curl_write_cb(void *ptr, size_t size, size_t nmemb, void *userp)
+{
+    size_t bytes = size * nmemb;
+    NSMutableData *buf = (NSMutableData *)userp;
+    [buf appendBytes:ptr length:bytes];
+    return bytes;
+}
+
+// [libcurl callback] Response header line ("Key: Value\r\n" or "HTTP/1.1 200 OK\r\n").
+// Parses into an NSMutableDictionary shared with the request. Status lines are ignored
+// (the status code is read via curl_easy_getinfo). Runs on the detached curl worker thread.
+static size_t asi_curl_header_cb(void *ptr, size_t size, size_t nmemb, void *userp)
+{
+    size_t bytes = size * nmemb;
+    NSMutableDictionary *headers = (NSMutableDictionary *)userp;
+    NSString *line = [[[NSString alloc] initWithBytes:ptr length:bytes encoding:NSUTF8StringEncoding] autorelease];
+    if (!line) { return bytes; }
+    // New response starts — clear previous headers (libcurl fires these on each redirect hop too)
+    if ([line hasPrefix:@"HTTP/"]) {
+        [headers removeAllObjects];
+        return bytes;
+    }
+    NSRange colon = [line rangeOfString:@":"];
+    if (colon.location == NSNotFound) { return bytes; }
+    NSString *key = [[line substringToIndex:colon.location]
+                     stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceCharacterSet]];
+    NSString *val = [[line substringFromIndex:colon.location + 1]
+                     stringByTrimmingCharactersInSet:[NSCharacterSet whitespaceAndNewlineCharacterSet]];
+    if ([key length]) { [headers setObject:val forKey:key]; }
+    return bytes;
+}
+
+// [libcurl callback] Progress / cancellation check. Returns non-zero to abort the transfer.
+// Runs on the detached curl worker thread.
+static int asi_curl_xferinfo_cb(void *clientp, curl_off_t dltotal, curl_off_t dlnow, curl_off_t ultotal, curl_off_t ulnow)
+{
+    ASIHTTPRequest *req = (ASIHTTPRequest *)clientp;
+    if ([req isCancelled]) { return 1; }
+    (void)dltotal; (void)dlnow; (void)ultotal; (void)ulnow;
+    return 0;
 }
 
