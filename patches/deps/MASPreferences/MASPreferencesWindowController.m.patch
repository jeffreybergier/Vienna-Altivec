+- (void)setSelectedViewController:(NSViewController <MASPreferencesViewController> *)controller;
+{
+    if (_selectedViewController == controller)
+        return;
+
+    if (_selectedViewController)
+    {
+        if (![_selectedViewController commitEditing])
