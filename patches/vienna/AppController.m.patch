+/* _showSyncPrefsDebug
+ * TEMP: Deferred helper to create and show the SyncPreferences window.
+ * Deferred via performSelector:afterDelay: so any exception is isolated
+ * from applicationDidFinishLaunching: and will appear in the log.
+ */
+-(void)_showSyncPrefsDebug
+{
+	static SyncPreferences * _syncPrefsDebug = nil;
+	if (!_syncPrefsDebug)
+		_syncPrefsDebug = [[SyncPreferences alloc] init];
+	if (_syncPrefsDebug)
+	{
+		[[_syncPrefsDebug window] center];
+		[NSApp activateIgnoringOtherApps:YES];
+		[[_syncPrefsDebug window] makeKeyAndOrderFront:nil];
+		[[_syncPrefsDebug window] orderFrontRegardless];
+	}
+}
