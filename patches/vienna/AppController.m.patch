+/* createNewGoogleReaderSubscription
+ * Create a new Open Reader subscription. The folder is tagged as a GoogleReader
+ * folder type so the refresh manager knows to use the GR sync engine.
+ */
+-(void)createNewGoogleReaderSubscription:(NSString *)url underFolder:(int)parentId withTitle:(NSString *)title afterChild:(int)predecessorId
+{
+	// Skip if already subscribed
+	if ([db folderFromFeedURL:url] != nil)
+		return;
+
+	NSString * feedName = (title && [title length] > 0) ? title : [Database untitledFeedFolderName];
+	[db beginTransaction];
+	int folderId = [db addGoogleReaderFolder:feedName underParent:parentId afterChild:predecessorId subscriptionURL:url];
+	[db commitTransaction];
+
+	if (folderId != -1)
+		[foldersTree selectFolder:folderId];
+}
