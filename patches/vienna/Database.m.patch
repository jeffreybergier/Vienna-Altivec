+/* markUnreadArticlesFromFolder
+ * Given an array of GUIDs that the server considers unread for this folder,
+ * reconcile the local read/unread state: mark unread anything in the list,
+ * mark read everything else.
+ */
+-(void)markUnreadArticlesFromFolder:(Folder *)folder guidArray:(NSArray *)guidArray
+{
+	int folderId = [folder itemId];
+	[self initArticleArray:folder];
+	NSLog(@"[Database.markUnreadArticlesFromFolder] folder='%@' serverUnread=%lu cachedArticles=%lu", [folder name], (unsigned long)[guidArray count], (unsigned long)[[folder articles] count]);
+
+	NSMutableSet * unreadSet = [NSMutableSet setWithCapacity:[guidArray count]];
+	NSEnumerator * ge = [guidArray objectEnumerator];
+	NSString * g;
+	while ((g = [ge nextObject]) != nil)
+		[unreadSet addObject:g];
+
+	NSArray * articles = [folder articles];
+	NSEnumerator * ae = [articles objectEnumerator];
+	Article * article;
+	while ((article = [ae nextObject]) != nil) {
+		BOOL shouldBeUnread = [unreadSet containsObject:[article guid]];
+		if (shouldBeUnread && [article isRead])
+			[self markArticleRead:folderId guid:[article guid] isRead:NO];
+		else if (!shouldBeUnread && ![article isRead])
+			[self markArticleRead:folderId guid:[article guid] isRead:YES];
+	}
+}
+
+/* markStarredArticlesFromFolder
+ * Given an array of GUIDs that the server considers starred for this folder,
+ * reconcile local flagged/unflagged state.
+ */
+-(void)markStarredArticlesFromFolder:(Folder *)folder guidArray:(NSArray *)guidArray
+{
+	int folderId = [folder itemId];
+	[self initArticleArray:folder];
+
+	NSMutableSet * starredSet = [NSMutableSet setWithCapacity:[guidArray count]];
+	NSEnumerator * ge = [guidArray objectEnumerator];
+	NSString * g;
+	while ((g = [ge nextObject]) != nil)
+		[starredSet addObject:g];
+
+	NSArray * articles = [folder articles];
+	NSEnumerator * ae = [articles objectEnumerator];
+	Article * article;
+	while ((article = [ae nextObject]) != nil) {
+		BOOL shouldBeStarred = [starredSet containsObject:[article guid]];
+		if (shouldBeStarred != [article isFlagged])
+			[self markArticleFlagged:folderId guid:[article guid] isFlagged:shouldBeStarred];
+	}
+}
